{
  "name": "@csisp/idp-server",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "format": "pnpm exec eslint . --fix && pnpm exec prettier --write .",
    "openapi:lint": "pnpm exec spectral lint api/openapi/**/*.yaml",
    "openapi:bundle": "pnpm exec swagger-cli bundle api/openapi/openapi.yaml -o dist/openapi/bundle.json -t json",
    "openapi:types": "pnpm exec openapi-typescript dist/openapi/bundle.json -o src/openapi-types/index.ts"
  },
  "dependencies": {
    "@csisp/config": "workspace:*",
    "@csisp/redis-sdk": "workspace:*",
    "@csisp/rpc": "workspace:*",
    "@csisp/utils": "workspace:*",
    "@nestjs/common": "catalog:node",
    "@nestjs/core": "catalog:node",
    "@nestjs/platform-express": "catalog:node",
    "@nestjs/serve-static": "^4.0.0",
    "@supabase/supabase-js": "^2.99.1",
    "class-transformer": "catalog:node",
    "class-validator": "catalog:node",
    "cookie-parser": "catalog:node",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "catalog:node",
    "rxjs": "catalog:node",
    "zod": "catalog:node"
  },
  "devDependencies": {
    "@nestjs/cli": "catalog:node",
    "@types/cookie-parser": "catalog:dev",
    "@types/express": "catalog:dev",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "catalog:dev",
    "nodemon": "catalog:dev",
    "pino-pretty": "catalog:",
    "tsx": "catalog:dev"
  }
}
