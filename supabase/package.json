{
  "name": "@csisp/supabase",
  "private": true,
  "type": "module",
  "scripts": {
    "login": "supabase login",
    "start:dev": "supabase start",
    "link": "infisical run  --env=staging -- sh -lc 'supabase link --project-ref \"$SUPABASE_URL_REF\"'",
    "db:pull": "supabase db pull",
    "db:reset:dev": "supabase db reset",
    "migrations:list": "supabase migration list",
    "upstash-health:serve": "infisical export --env=staging > functions/upstash-health/.env && supabase functions serve --no-verify-jwt"
  }
}
