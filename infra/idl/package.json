{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@csisp/idl",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsx ./cli/index.ts gen"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./backoffice": {
      "require": "./dist/backoffice.js",
      "types": "./dist/backoffice.d.ts"
    },
    "./backend": {
      "require": "./dist/backend.js",
      "types": "./dist/backend.d.ts"
    },
    "./idp": {
      "require": "./dist/idp.js",
      "types": "./dist/idp.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "backoffice": [
        "dist/backoffice"
      ],
      "backend": [
        "dist/backend"
      ],
      "idp": [
        "dist/idp"
      ]
    }
  },
  "dependencies": {
    "@creditkarma/thrift-server-core": "^1.0.4",
    "@csisp/utils": "workspace:*",
    "pino": "catalog:"
  },
  "devDependencies": {
    "@creditkarma/thrift-typescript": "^3.7.6",
    "pino-pretty": "catalog:",
    "tsx": "catalog:dev"
  }
}
