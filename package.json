{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "csisp-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "pnpm prettier --write . && eslint . --fix && stylelint '**/*.{css,scss,vue}' --fix",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "infisical:login": "infisical login --domain \"$npm_config_INFISICAL_API_URL\"",
    "dev:backend-integrated": "infisical run -- turbo run dev --filter=@csisp/backend-integrated",
    "dev:backoffice": "infisical run -- turbo run dev --filter=@csisp/backoffice",
    "dev:idp:server": "infisical run -- turbo run dev --filter=@csisp/idp-server",
    "stag:idp:server": "infisical run  --env=staging -- turbo run dev --filter=@csisp/idp-server",
    "dev:idp:client": "infisical run -- turbo run dev --filter=@csisp/idp-client",
    "dev:bff": "infisical run -- turbo run dev --filter=@csisp/bff",
    "dev:admin": "infisical run -- turbo run dev --filter=@csisp/frontend-admin",
    "dev:portal": "infisical run -- turbo run dev --filter=@csisp/frontend-portal",
    "build": "turbo build"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts,jsx,tsx,vue}": [
      "eslint --fix"
    ],
    "**/*.{js,mjs,cjs,ts,jsx,tsx,vue,html,json,css,scss,md}": [
      "prettier --write"
    ],
    "**/*.{css,scss,vue}": [
      "stylelint --fix"
    ]
  },
  "devDependencies": {
    "@csisp/utils": "workspace:*",
    "@eslint/js": "^9.39.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/glob": "^9.0.0",
    "@types/node": "^18.19.0",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.5.1",
    "glob": "^13.0.3",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.6",
    "postcss-html": "^1.8.0",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@alicloud/openapi-core",
      "@nestjs/core",
      "@parcel/watcher",
      "argon2",
      "bcrypt",
      "esbuild",
      "sharp",
      "vue-demi",
      "vue-echarts"
    ]
  }
}
