{
  "name": "@csisp/contracts",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsx scripts/generate-contract-type-exports.ts",
    "build": "tsup",
    "format": "pnpm exec eslint . --fix && pnpm exec prettier --write ."
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "dependencies": {
    "@csisp-api/bff-idp-server": "0.2.2",
    "@ts-rest/core": "^3.52.1",
    "zod": "catalog:node"
  }
}
